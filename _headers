# ============================================================
#  Yahavi Forge — Cloudflare Pages security headers
#  Docs: https://developers.cloudflare.com/pages/configuration/headers/
#
#  Design rationale:
#   • Most-specific rule wins; broader rules apply to everything else.
#   • CORS: HTML pages must NOT carry Access-Control-Allow-Origin — only
#     explicitly public static assets may expose it, and only to trusted origins.
#   • CSP: unsafe-inline is required while scripts/styles are inline; the
#     meaningful gains come from object-src 'none', base-uri 'self',
#     frame-ancestors 'none', and the connect-src allowlist.
#   • Cookies: we don't set our own Set-Cookie in CF Pages; Supabase PKCE
#     sets its code_verifier cookie — we configure that in hk-auth.js.
#     This file covers the CF-level __Host- prefix preference and adds
#     the cookie-policy advisory header.
#   • Sensitive probes (.env, .git, package.json, etc.) are handled in
#     _redirects (real 404). Headers alone cannot change status codes.
# ============================================================

# ─── BLOCK: never expose these — handled by _redirects, but belt+suspenders ───
/.env
  X-Robots-Tag: noindex, noarchive
/.git/*
  X-Robots-Tag: noindex, noarchive
/package.json
  X-Robots-Tag: noindex, noarchive

# ─── PUBLIC STATIC ASSETS (JS, CSS, fonts, images) ───
# Cloudflare Pages may otherwise add Access-Control-Allow-Origin: * here.
# We restrict to our own origin so third-party pages cannot read these XHR-style.
/js/*
  Access-Control-Allow-Origin: https://forge.hackknow.com
  Cross-Origin-Resource-Policy: same-site
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/*.css
  Access-Control-Allow-Origin: https://forge.hackknow.com
  Cross-Origin-Resource-Policy: same-site
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

# Google Fonts and CDN-loaded scripts need to be loadable cross-origin by
# the browser — but we do NOT want other servers to fetch them cross-origin.
# Cross-Origin-Resource-Policy: same-site achieves this.

# ─── APP SHELL & HTML PAGES ───
# HTML responses MUST NOT carry CORS headers — browsers only need CORS on
# XHR/fetch, and no legitimate consumer should be fetching our HTML from
# another origin. Remove the wildcard completely.
/*.html
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self' https://ndrnrblhlkgugyvzsbba.supabase.co; upgrade-insecure-requests; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://checkout.razorpay.com; worker-src 'none'; manifest-src 'self'; connect-src 'self' https://ndrnrblhlkgugyvzsbba.supabase.co https://*.supabase.co https://api.groq.com https://generativelanguage.googleapis.com https://openrouter.ai/api https://api.together.xyz https://api.mistral.ai https://api.cohere.ai https://lottie.host https://api.razorpay.com https://checkout.razorpay.com
  X-Permitted-Cross-Domain-Policies: none

# ─── CATCH-ALL (all other paths — applies if no more-specific rule above matches) ───
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self' https://ndrnrblhlkgugyvzsbba.supabase.co; upgrade-insecure-requests; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://checkout.razorpay.com; worker-src 'none'; manifest-src 'self'; connect-src 'self' https://ndrnrblhlkgugyvzsbba.supabase.co https://*.supabase.co https://api.groq.com https://generativelanguage.googleapis.com https://openrouter.ai/api https://api.together.xyz https://api.mistral.ai https://api.cohere.ai https://api.razorpay.com https://checkout.razorpay.com
  X-Permitted-Cross-Domain-Policies: none

# ─── OPERATIONAL FILES — explicit content-type, long cache ───
/robots.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400
  X-Content-Type-Options: nosniff

/sitemap.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=86400
  X-Content-Type-Options: nosniff

/manifest.json
  Content-Type: application/manifest+json; charset=utf-8
  Cache-Control: public, max-age=86400
  Cross-Origin-Resource-Policy: same-origin

/.well-known/security.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400
