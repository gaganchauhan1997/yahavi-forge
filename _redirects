/nuxt.config.*         /404.html  404
/wrangler.toml         /404.html  404
/wrangler.json         /404.html  404

# API / schema discovery endpoints (no API lives in CF Pages; Workers handle /api/*)
/openapi.json          /404.html  404
/swagger.json          /404.html  404
/swagger.yaml          /404.html  404
/api-docs              /404.html  404
